APP_NAME="Solarhesap"
APP_VERSION="v0.2.0"
APP_DESCRIPTION="Solarhesap is a Tübitak 2209 project"
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development
APP_DEBUG=True

PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_3
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

LOG_BASE_LEVEL=DEBUG
LOG_STREAM_HANDLER=True
LOG_DIR=./logs

OPENMETEO_TIMEOUT=30
PVGIS_TIMEOUT=90

# Real domain(s) the browser reaches in production — comma-separated list
# Example: ALLOWED_ORIGINS=https://solarhesap.com,https://www.solarhesap.com
# In development (APP_ENV=development) this value is ignored (wildcard is used).
# If left empty in production, all origins are allowed (insecure).
ALLOWED_ORIGINS=
